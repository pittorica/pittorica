{
  "name": "pittorica",
  "version": "0.26.3",
  "private": false,
  "description": "Pittorica is a painterly, CSS-first UI framework that brings elegant, lightweight structure to modern interfaces.",
  "keywords": [
    "ui",
    "pittorica"
  ],
  "homepage": "https://pittorica.dcdavidev.me",
  "license": "MIT",
  "author": {
    "name": "Davide Di Criscito"
  },
  "type": "module",
  "exports": {
    ".": "./styles/index.css",
    "./styles/*": "./styles/*",
    "./react": {
      "types": "./react/dist/pittorica-react.d.ts",
      "import": "./react/dist/pittorica-react.js",
      "require": "./react/dist/pittorica-react.umd.cjs"
    }
  },
  "main": "./styles/index.css",
  "files": [
    "styles",
    "react/dist"
  ],
  "scripts": {
    "build:react": "vite build -c react/vite.config.ts",
    "depsup": "pnpx depsup@latest",
    "dev": "turbo run dev",
    "fmt": "pnpx prettier --ignore-unknown --write .",
    "lint": "pnpx eslint --no-warn-ignored --fix .",
    "lint:fmt": "pnpm run lint && pnpm run fmt"
  },
  "commitlint": {
    "extends": [
      "spellbookx"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "prettier": "prettier-config-spellbookx/base",
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@tabler/icons-react": "^3.40.0",
    "clsx": "^2.1.1",
    "input-otp": "^1.4.2",
    "motion": "^12.36.0",
    "react-focus-lock": "^2.13.7",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@cspell/cspell-types": "^9.7.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "commitizen": "^4.3.1",
    "commitlint-config-spellbookx": "^0.11.1",
    "cspell": "^9.7.0",
    "cspell-config-spellbookx": "^0.11.1",
    "cz-git": "^1.12.0",
    "eslint": "^10.0.3",
    "eslint-plugin-spellbookx": "^0.11.1",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-config-spellbookx": "^0.11.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-ini": "^1.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-properties": "^0.3.1",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prettier-plugin-toml": "^2.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "publishConfig": {
    "access": "public"
  }
}
